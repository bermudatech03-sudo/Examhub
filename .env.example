# ============================================================
# ExamHub — Environment Configuration
# Copy to .env and fill in your values
# ============================================================

#-----FOR LOCAL CHECK----
DATABASE_URL=postgresql://examhub:examhub_secret@localhost:5432/examhub
REDIS_URL=redis://localhost:6379
JWT_SECRET=any-random-string-at-least-32-characters-long
NODE_ENV=development


# --- General ---
#NODE_ENV=production
LOG_LEVEL=info

# --- Database ---
POSTGRES_USER=examhub
POSTGRES_PASSWORD=postgres
POSTGRES_DB=examhub
POSTGRES_PORT=5432

# Prisma connection string (auto-built from above in docker-compose)
#DATABASE_URL=postgresql://examhub:change_this_strong_password@localhost:5432/examhub

# --- Redis ---
REDIS_PASSWORD=change_this_redis_password
REDIS_PORT=6379
#REDIS_URL=redis://:change_this_redis_password@localhost:6379

# --- JWT ---
#JWT_SECRET=change_this_to_a_very_long_random_secret_minimum_64_chars
JWT_EXPIRES_IN=7d

# --- S3 / MinIO ---
MINIO_ROOT_USER=examhub_minio
MINIO_ROOT_PASSWORD=change_this_minio_password
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_BUCKET=examhub
# For production AWS S3, remove S3_ENDPOINT:
S3_ENDPOINT=http://localhost:9000
AWS_ACCESS_KEY_ID=examhub_minio
AWS_SECRET_ACCESS_KEY=change_this_minio_password
AWS_REGION=us-east-1

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
EMAIL_FROM=noreply@examhub.io

# --- URLs ---
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# --- Ports ---
BACKEND_PORT=4000
FRONTEND_PORT=3000

# --- Rate Limiting ---
RATE_LIMIT_MAX=100
